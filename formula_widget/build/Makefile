.PHONY : test_layout_autogen/mocs_compilation.i

# target to preprocess a source file
test_layout_autogen/mocs_compilation.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_layout.dir/build.make CMakeFiles/test_layout.dir/test_layout_autogen/mocs_compilation.cpp.i
.PHONY : test_layout_autogen/mocs_compilation.cpp.i

test_layout_autogen/mocs_compilation.s: test_layout_autogen/mocs_compilation.cpp.s
.PHONY : test_layout_autogen/mocs_compilation.s

# target to generate assembly for a file
test_layout_autogen/mocs_compilation.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_layout.dir/build.make CMakeFiles/test_layout.dir/test_layout_autogen/mocs_compilation.cpp.s
.PHONY : test_layout_autogen/mocs_compilation.cpp.s

